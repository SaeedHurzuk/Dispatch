#!/usr/bin/env bash
# =============================================================================
# Dispatch — Production-grade transparent rsync wrapper
# Version: 1.1.0
#
# Features:
#   - Transparent drop-in replacement for rsync (all args pass through)
#   - SMTP email notifications via curl (HTML + plain text)
#   - Notify on: always | failure | success | warnings
#   - Optional start notification email
#   - Webhook support (Slack, Discord, ntfy.sh, generic HTTP POST — auto-detected)
#   - Webhook test without running a sync (--webhook-test)
#   - Dead man's switch / heartbeat ping (Healthchecks.io, Uptime Kuma)
#   - SMTP connection test without running a sync (--smtp-test)
#   - Retry logic with configurable attempts and backoff delay
#   - Lock file to prevent concurrent runs on the same destination
#   - Config file support (/etc/dispatch.conf + ~/.dispatch.conf)
#   - Dry-run detection (clearly flagged in email)
#   - Signal trapping (SIGINT/SIGTERM — sends failure email on kill)
#   - Stats parsing (files transferred, size, speed, pulled into email header)
#   - Stats captured in-memory — available with or without --logfile
#   - Log file support with automatic rotation (keep N recent logs)
#   - Multiple SMTP recipients (comma-separated)
#   - Pre/post hook scripts
#   - Quiet mode (suppress wrapper output, rsync output still shown)
#   - Runtime env var overrides for all SMTP settings
#   - Anti-recursion: auto-locates real rsync binary, never calls itself
#
# Install:
#   sudo cp rsync /usr/local/bin/rsync
#   sudo chmod +x /usr/local/bin/rsync
#
# Wrapper flags (all stripped before reaching real rsync):
#   --smtp-enable          Enable SMTP for this run
#   --smtp-disable         Disable SMTP for this run (default)
#   --smtp-test            Test SMTP connection and exit (no sync runs)
#   --logfile              Enable log file for this run
#   --notify=always        Email on success and failure (default when SMTP on)
#   --notify=failure       Email only on failure
#   --notify=success       Email only on success
#   --notify=warnings      Email only on exit-code-24 (partial transfer)
#   --notify-start         Also send an email when the sync begins
#   --html-email           Send styled HTML email (default: on)
#   --no-html-email        Force plain text email
#   --retry=N              Retry up to N times on failure (default: 0)
#   --retry-delay=N        Seconds to wait between retries (default: 30)
#   --pre-hook=/path       Script to run before rsync
#   --post-hook=/path      Script to run after rsync
#   --no-lock              Disable lock file, allow concurrent runs
#   --webhook=URL          POST notification to URL on completion
#   --webhook-on=EVENT     When to fire webhook: always|failure|success|warnings (default: always)
#   --webhook-test         Test webhook delivery and exit (no sync runs)
#   --ping-url=URL         GET this URL on success — dead man's switch / heartbeat
#   --quiet                Suppress wrapper header/footer output
#   --upgrade              Self-update Dispatch to the latest version
#   --version              Print version and exit
#   --help, -h             Show Dispatch wrapper help
#   --rsync-help           Show the real rsync binary's own --help output
#
# Config file (optional, sourced in order — later overrides earlier):
#   /etc/dispatch.conf
#   ~/.dispatch.conf
#
# Environment variable overrides:
#   DISPATCH_HOST, DISPATCH_PORT, DISPATCH_USER, DISPATCH_PASS
#   DISPATCH_FROM, DISPATCH_TO, DISPATCH_TLS
# =============================================================================

set -euo pipefail

# ── Version ───────────────────────────────────────────────────────────────────
readonly VERSION="1.1.0"
readonly SCRIPT_NAME="dispatch"

# =============================================================================
# DEFAULT CONFIGURATION — overridden by config file, env vars, or CLI flags
# =============================================================================

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="you@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="rsync@example.com"
SMTP_TO="recipient@example.com"   # Comma-separate for multiple: "a@x.com,b@x.com"
SMTP_TLS="starttls"               # starttls | ssl | none

SMTP_ENABLED=false                # Default off — use --smtp-enable per run
HTML_EMAIL=true                   # Default on — use --no-html-email to force plain text

# ── Notifications ─────────────────────────────────────────────────────────────
NOTIFY_ON="always"                # always | failure | success | warnings
NOTIFY_START=false                # Send email when sync starts

# ── Webhooks ──────────────────────────────────────────────────────────────────
WEBHOOK_URL=""                    # POST to this URL on completion (Slack, Discord, ntfy.sh...)
WEBHOOK_ON="always"               # always | failure | success | warnings

# ── Dead man's switch ─────────────────────────────────────────────────────────
PING_URL=""                       # GET this URL on success only (Healthchecks.io, Uptime Kuma...)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_ENABLED=false                 # Default off — use --logfile per run
LOG_DIR="/var/log/dispatch"
LOG_ROTATE_KEEP=30                # Number of log files to keep

# ── Lock ──────────────────────────────────────────────────────────────────────
LOCK_DIR="/tmp/dispatch-locks"  # Lock files live here
NO_LOCK=false                     # Set true with --no-lock to skip locking

# ── Retry ─────────────────────────────────────────────────────────────────────
RETRY_COUNT=0                     # Retry attempts on failure (0 = no retry)
RETRY_DELAY=30                    # Seconds between retries

# ── Hooks ─────────────────────────────────────────────────────────────────────
PRE_HOOK=""                       # Path to script to run before rsync
POST_HOOK=""                      # Path to script to run after rsync

# ── Misc ──────────────────────────────────────────────────────────────────────
QUIET=false                       # Suppress wrapper header/footer

# =============================================================================

# ── Source config files if present ───────────────────────────────────────────
[[ -f /etc/dispatch.conf     ]] && source /etc/dispatch.conf
[[ -f "$HOME/.dispatch.conf" ]] && source "$HOME/.dispatch.conf"

# ── Environment variable overrides ───────────────────────────────────────────
SMTP_HOST="${DISPATCH_HOST:-$SMTP_HOST}"
SMTP_PORT="${DISPATCH_PORT:-$SMTP_PORT}"
SMTP_USER="${DISPATCH_USER:-$SMTP_USER}"
SMTP_PASS="${DISPATCH_PASS:-$SMTP_PASS}"
SMTP_FROM="${DISPATCH_FROM:-$SMTP_FROM}"
SMTP_TO="${DISPATCH_TO:-$SMTP_TO}"
SMTP_TLS="${DISPATCH_TLS:-$SMTP_TLS}"

# ── Locate the real rsync binary (anti-recursion) ────────────────────────────
RSYNC_BIN=""
SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

while IFS= read -r -d ':' dir; do
  dir="${dir%/}"
  [[ -z "$dir" ]] && continue
  [[ "$dir" == "$SELF_DIR" ]] && continue
  if [[ -x "$dir/rsync" ]]; then
    RSYNC_BIN="$dir/rsync"
    break
  fi
done <<< "${PATH}:"

if [[ -z "$RSYNC_BIN" ]]; then
  echo -e "\033[1;33m[⚠] rsync binary not found in PATH — attempting to install...\033[0m" >&2

  _installed=false
  if   command -v apt-get &>/dev/null; then apt-get update -qq && apt-get install -y -qq rsync && _installed=true
  elif command -v dnf     &>/dev/null; then dnf install -y -q rsync                           && _installed=true
  elif command -v yum     &>/dev/null; then yum install -y -q rsync                           && _installed=true
  elif command -v pacman  &>/dev/null; then pacman -Sy --noconfirm rsync                      && _installed=true
  elif command -v zypper  &>/dev/null; then zypper install -y rsync                           && _installed=true
  elif command -v brew    &>/dev/null; then brew install rsync                                && _installed=true
  fi

  if ! $_installed; then
    echo -e "\033[0;31m[✘] FATAL: Could not locate or install rsync. Please install it manually:\033[0m" >&2
    echo "      apt install rsync  /  dnf install rsync  /  brew install rsync" >&2
    exit 1
  fi

  while IFS= read -r -d ':' dir; do
    dir="${dir%/}"
    [[ -z "$dir" ]] && continue
    [[ "$dir" == "$SELF_DIR" ]] && continue
    if [[ -x "$dir/rsync" ]]; then
      RSYNC_BIN="$dir/rsync"
      break
    fi
  done <<< "${PATH}:"

  if [[ -z "$RSYNC_BIN" ]]; then
    echo -e "\033[0;31m[✘] FATAL: rsync was installed but still cannot be found in PATH.\033[0m" >&2
    exit 1
  fi

  echo -e "\033[0;32m[✔] rsync installed and located at: ${RSYNC_BIN}\033[0m" >&2
fi

# ── Colour codes ──────────────────────────────────────────────────────────────
if [ -t 1 ] || [ -t 2 ] || { [ -e /dev/tty ] && tty -s 2>/dev/null; }; then
  RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
  CYAN=$'\033[0;36m'; BOLD=$'\033[1m'; DIM=$'\033[2m'; RESET=$'\033[0m'
else
  RED=''; GREEN=''; YELLOW=''; CYAN=''; BOLD=''; DIM=''; RESET=''
fi

# ── Helpers ───────────────────────────────────────────────────────────────────
ts()      { date '+%Y-%m-%d %H:%M:%S'; }
log()     { $QUIET || echo -e "${CYAN}[$(ts)]${RESET} $*"; }
success() { $QUIET || echo -e "${GREEN}[✔] $*${RESET}"; }
warn()    { echo -e "${YELLOW}[⚠] $*${RESET}"; }
error()   { echo -e "${RED}[✘] $*${RESET}" >&2; }
die()     { error "$*"; exit 1; }
banner()  { $QUIET || echo -e "${BOLD}════════════════════════════════════════════════════${RESET}"; }

# ── Usage ─────────────────────────────────────────────────────────────────────
usage() {
  cat <<EOF

${BOLD}${SCRIPT_NAME} v${VERSION}${RESET} -- Transparent rsync wrapper with SMTP notifications

${BOLD}Usage:${RESET}
  rsync [WRAPPER OPTIONS] [RSYNC OPTIONS] <source> <destination>

${BOLD}Wrapper Options:${RESET}
  --smtp-enable            Enable SMTP email notification for this run
  --smtp-disable           Disable SMTP (default)
  --smtp-test              Test SMTP connection and exit — no sync runs
  --logfile                Save output to timestamped log file
  --notify=always          Email on success and failure (default)
  --notify=failure         Email only on failure
  --notify=success         Email only on success
  --notify=warnings        Email only on exit-code-24 (partial transfer)
  --notify-start           Send an email when the sync starts
  --html-email             Send styled HTML email (default: plain text)
  --no-html-email          Force plain text even if HTML_EMAIL=true in config
  --retry=N                Retry N times on failure before giving up
  --retry-delay=N          Seconds to wait between retries (default: 30)
  --pre-hook=/path         Run this script before rsync executes
  --post-hook=/path        Run this script after rsync completes
  --no-lock                Disable lock file, allow concurrent runs
  --webhook=URL            POST notification to URL on completion
  --webhook-on=EVENT       When to fire webhook: always|failure|success|warnings (default: always)
  --webhook-test           Test webhook delivery and exit — no sync runs
  --ping-url=URL           GET this URL on success — dead man's switch / heartbeat
  --quiet                  Suppress wrapper header/footer (rsync output unaffected)
  --rsync-help             Show the real rsync binary's own --help output
  --upgrade                Self-update Dispatch to the latest version
  --version                Print version and exit
  --help, -h               Show this help

${BOLD}Examples:${RESET}
  rsync -avhr --progress /src/ /dst/
  rsync --smtp-enable -avhr /src/ /dst/
  rsync --smtp-enable --notify=failure --retry=3 -avhr /src/ /dst/
  rsync --smtp-enable --html-email --logfile --notify-start -avhr /src/ /dst/
  rsync --webhook=https://hooks.slack.com/services/xxx -avhr /src/ /dst/
  rsync --ping-url=https://hc-ping.com/your-uuid --smtp-enable -avhr /src/ /dst/
  rsync --smtp-test

${BOLD}Config files (sourced in order):${RESET}
  /etc/dispatch.conf
  ~/.dispatch.conf

${BOLD}Environment overrides:${RESET}
  DISPATCH_HOST, DISPATCH_PORT, DISPATCH_USER
  DISPATCH_PASS, DISPATCH_FROM, DISPATCH_TO, DISPATCH_TLS

${BOLD}Provider quick reference:${RESET}
  Gmail:       smtp.gmail.com        port 587  starttls  (requires App Password)
  Office 365:  smtp.office365.com    port 587  starttls
  Outlook.com: smtp-mail.outlook.com port 587  starttls
  SendGrid:    smtp.sendgrid.net     port 587  starttls

EOF
  exit 0
}

# ── Argument parsing ──────────────────────────────────────────────────────────
RSYNC_ARGS=()
IS_DRY_RUN=false
_SMTP_TEST=false
_DO_UPGRADE=false
_WEBHOOK_TEST=false

for arg in "$@"; do
  case "$arg" in
    --smtp-enable)      SMTP_ENABLED=true ;;
    --smtp-disable)     SMTP_ENABLED=false ;;
    --smtp-test)        _SMTP_TEST=true ;;
    --logfile)          LOG_ENABLED=true ;;
    --notify=always)    NOTIFY_ON="always" ;;
    --notify=failure)   NOTIFY_ON="failure" ;;
    --notify=success)   NOTIFY_ON="success" ;;
    --notify=warnings)  NOTIFY_ON="warnings" ;;
    --notify-start)     NOTIFY_START=true ;;
    --html-email)       HTML_EMAIL=true ;;
    --no-html-email)    HTML_EMAIL=false ;;
    --retry=*)          RETRY_COUNT="${arg#--retry=}" ;;
    --retry-delay=*)    RETRY_DELAY="${arg#--retry-delay=}" ;;
    --pre-hook=*)       PRE_HOOK="${arg#--pre-hook=}" ;;
    --post-hook=*)      POST_HOOK="${arg#--post-hook=}" ;;
    --no-lock)          NO_LOCK=true ;;
    --webhook=*)        WEBHOOK_URL="${arg#--webhook=}" ;;
    --webhook-on=*)     WEBHOOK_ON="${arg#--webhook-on=}" ;;
    --webhook-test)     _WEBHOOK_TEST=true ;;
    --ping-url=*)       PING_URL="${arg#--ping-url=}" ;;
    --quiet)            QUIET=true ;;
    --rsync-help)       exec "$RSYNC_BIN" --help ;;
    --upgrade)          _DO_UPGRADE=true ;;
    --version)
