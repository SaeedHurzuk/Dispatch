# ── SMTP test ─────────────────────────────────────────────────────────────────
smtp_test() {
  echo ""
  log "Testing SMTP connection to ${SMTP_HOST}:${SMTP_PORT}..."
  log "From : ${SMTP_FROM}"
  log "To   : ${SMTP_TO%%,*}"
  echo ""

  local tls_flag=""
  case "$SMTP_TLS" in
    starttls) tls_flag="--ssl-reqd" ;;
    ssl)      tls_flag="--ssl"      ;;
    none)     tls_flag=""           ;;
  esac

  local exit_code=0
  curl --silent --show-error --connect-timeout 10 \
    --url "smtp://${SMTP_HOST}:${SMTP_PORT}" \
    ${tls_flag} \
    --user "${SMTP_USER}:${SMTP_PASS}" \
    --mail-from "${SMTP_FROM}" \
    --mail-rcpt "${SMTP_TO%%,*}" \
    --upload-file - <<< $'Subject: Dispatch connection test\r\n\r\nSMTP connection test from Dispatch wrapper.' \
    && exit_code=0 || exit_code=$?

  echo ""
  if [[ "$exit_code" -eq 0 ]]; then
    echo -e "${GREEN}[✔] SMTP test passed -- check ${SMTP_TO%%,*} for the test email.${RESET}"
  else
    echo -e "${RED}[✘] SMTP test failed (curl exit: ${exit_code})${RESET}" >&2
    echo -e "${YELLOW}[⚠] Debug: curl -v --url smtp://${SMTP_HOST}:${SMTP_PORT} ${tls_flag} --user '${SMTP_USER}:<pass>' --mail-from '${SMTP_FROM}' --mail-rcpt '${SMTP_TO%%,*}'${RESET}"
  fi
  echo ""
  return "$exit_code"
}

if $_SMTP_TEST; then
  smtp_test
  exit $?
fi

if $_WEBHOOK_TEST; then
  webhook_test
  exit $?
fi

# ── Self-upgrade ──────────────────────────────────────────────────────────────
do_upgrade() {
  local installer_url="https://raw.githubusercontent.com/SaeedHurzuk/Dispatch/refs/heads/main/install.sh"

  # Upgrading writes to /usr/local/bin — must be root
  if [[ "$EUID" -ne 0 ]]; then
    echo ""
    error "rsync --upgrade must be run as root (it writes to /usr/local/bin)."
    echo -e "  Run: ${BOLD}sudo rsync --upgrade${RESET}" >&2
    echo ""
    exit 1
  fi

  echo ""
  log "Dispatch self-upgrade"
  log "Current version : v${VERSION}"
  log "Fetching latest installer from GitHub..."

  if ! command -v curl &>/dev/null; then
    die "curl is required for --upgrade. Install it first: apt install curl"
  fi

  local tmp_installer
  tmp_installer=$(mktemp /tmp/dispatch-installer.XXXXXX)

  local fetch_exit=0
  curl -fsSL "$installer_url" -o "$tmp_installer" || fetch_exit=$?

  if [[ "$fetch_exit" -ne 0 ]]; then
    rm -f "$tmp_installer"
    die "Failed to fetch installer (curl exit: ${fetch_exit}). Check your internet connection."
  fi

  bash -n "$tmp_installer" || { rm -f "$tmp_installer"; die "Downloaded installer failed syntax check — aborting."; }

  log "Running installer --update..."
  echo ""
  bash "$tmp_installer" --update
  local upgrade_exit=$?
  rm -f "$tmp_installer"
  exit "$upgrade_exit"
}

if $_DO_UPGRADE; then
  do_upgrade
fi



# ── Proxy bare call to real rsync ─────────────────────────────────────────────
if [[ ${#RSYNC_ARGS[@]} -eq 0 ]]; then
  exec "$RSYNC_BIN"
fi

# ── Input validation ──────────────────────────────────────────────────────────
[[ "$RETRY_COUNT"  =~ ^[0-9]+$ ]] || die "--retry value must be a non-negative integer"
[[ "$RETRY_DELAY"  =~ ^[0-9]+$ ]] || die "--retry-delay value must be a non-negative integer"

if [[ -n "$PRE_HOOK" ]]; then
  [[ -f "$PRE_HOOK" && -x "$PRE_HOOK" ]] || die "Pre-hook not found or not executable: '$PRE_HOOK'"
fi
if [[ -n "$POST_HOOK" ]]; then
  [[ -f "$POST_HOOK" && -x "$POST_HOOK" ]] || die "Post-hook not found or not executable: '$POST_HOOK'"
fi

case "$NOTIFY_ON" in
  always|failure|success|warnings) ;;
  *) die "Invalid --notify value: '$NOTIFY_ON'. Use: always | failure | success | warnings" ;;
esac

case "$WEBHOOK_ON" in
  always|failure|success|warnings) ;;
  *) die "Invalid --webhook-on value: '$WEBHOOK_ON'. Use: always | failure | success | warnings" ;;
esac

# ── Dependency check ──────────────────────────────────────────────────────────
command -v curl &>/dev/null || die "'curl' is not installed. Run: apt install curl"

# ── Extract source and destination for email subject ─────────────────────────
_positional=()
for _a in "${RSYNC_ARGS[@]}"; do
  [[ "$_a" != -* ]] && _positional+=("$_a")
done
SRC_ARG=""
DEST_ARG=""
if [[ ${#_positional[@]} -ge 2 ]]; then
  SRC_ARG="${_positional[-2]}"
  DEST_ARG="${_positional[-1]}"
elif [[ ${#_positional[@]} -eq 1 ]]; then
  DEST_ARG="${_positional[0]}"
fi
unset _positional _a

# ── Log file setup ────────────────────────────────────────────────────────────
LOG_FILE=""
TIMESTAMP=$(date '+%Y%m%d_%H%M%S')

if $LOG_ENABLED; then
  mkdir -p "$LOG_DIR" || die "Cannot create log directory: '$LOG_DIR'"
  LOG_FILE="${LOG_DIR}/rsync_${TIMESTAMP}.log"
fi

# ── Stats capture temp file ───────────────────────────────────────────────────
STATS_TMP=$(mktemp /tmp/dispatch-stats.XXXXXX)
trap 'rm -f "$STATS_TMP"' EXIT

# ── Lock file ─────────────────────────────────────────────────────────────────
DEST_ARG_LOCK="${RSYNC_ARGS[-1]}"
LOCK_KEY=$(echo "$DEST_ARG_LOCK" | tr '/' '_' | tr -cd '[:alnum:]_-')
LOCK_FILE="${LOCK_DIR}/Dispatch_${LOCK_KEY}.lock"

acquire_lock() {
  $NO_LOCK && return 0
  mkdir -p "$LOCK_DIR"
  if [[ -f "$LOCK_FILE" ]]; then
    local existing_pid
    existing_pid=$(cat "$LOCK_FILE" 2>/dev/null || echo "")
    if [[ -n "$existing_pid" ]] && kill -0 "$existing_pid" 2>/dev/null; then
      die "Another rsync to the same destination is already running (PID: $existing_pid). Lock: $LOCK_FILE"
    else
      warn "Stale lock file found (PID $existing_pid no longer running). Removing."
      rm -f "$LOCK_FILE"
    fi
  fi
  echo $$ > "$LOCK_FILE"
}

release_lock() {
  $NO_LOCK && return 0
  rm -f "$LOCK_FILE"
}

# ── Output helpers (stdout + optional log file) ───────────────────────────────
tee_output() {
  if $LOG_ENABLED && [[ -n "$LOG_FILE" ]]; then
    tee -a "$STATS_TMP" | tee -a "$LOG_FILE"
  else
    tee -a "$STATS_TMP"
  fi
}

write_output() {
  if $LOG_ENABLED && [[ -n "$LOG_FILE" ]]; then
    echo "$*" | tee -a "$STATS_TMP" | tee -a "$LOG_FILE"
  else
    echo "$*" | tee -a "$STATS_TMP"
  fi
}

# ── Log rotation ──────────────────────────────────────────────────────────────
rotate_logs() {
  if $LOG_ENABLED && [[ -d "$LOG_DIR" ]]; then
    local count
    count=$(ls -1 "${LOG_DIR}"/rsync_*.log 2>/dev/null | wc -l)
    if [[ "$count" -gt "$LOG_ROTATE_KEEP" ]]; then
      ls -1t "${LOG_DIR}"/rsync_*.log | tail -n +"$((LOG_ROTATE_KEEP + 1))" | xargs rm -f
      log "Log rotation: kept ${LOG_ROTATE_KEEP} most recent, removed $((count - LOG_ROTATE_KEEP)) old files."
    fi
  fi
}

# ── Parse stats from captured output ─────────────────────────────────────────
parse_rsync_stats() {
  if [[ ! -s "$STATS_TMP" ]]; then
    PARSED_STATS=""
    return
  fi
  local files speed sent
  files=$(grep -oE 'Number of regular files transferred: [0-9,]+' "$STATS_TMP" 2>/dev/null | sed 's/Number of regular files transferred: //' || true)
  speed=$(grep -oE 'Transfer rate: [^
]+' "$STATS_TMP" 2>/dev/null | sed 's/Transfer rate: //' | head -1 || true)
  sent=$(grep -oE 'Total transferred file size: [^
]+' "$STATS_TMP" 2>/dev/null | sed 's/Total transferred file size: //' || true)

  if [[ -n "$files" || -n "$sent" || -n "$speed" ]]; then
    PARSED_STATS=""
    [[ -n "$files" ]] && PARSED_STATS+="Files transferred : ${files}\n"
    [[ -n "$sent"  ]] && PARSED_STATS+="Data transferred  : ${sent}\n"
    [[ -n "$speed" ]] && PARSED_STATS+="Transfer rate     : ${speed}"
    PARSED_STATS=$(echo -e "$PARSED_STATS")
  else
    PARSED_STATS=""
  fi
}

# ── SMTP send ─────────────────────────────────────────────────────────────────
send_smtp_email() {
  local subject="$1"
  local body_plain="$2"
  local body_html="$3"
  local boundary="dispatch_boundary_${TIMESTAMP}"

  local tmp_mail
  tmp_mail=$(mktemp /tmp/dispatch-mail.XXXXXX)

  if $HTML_EMAIL; then
    cat > "$tmp_mail" <<EOF
From: ${SCRIPT_NAME} <${SMTP_FROM}>
To: ${SMTP_TO}
Subject: ${subject}
Date: $(date -R)
MIME-Version: 1.0
Content-Type: multipart/alternative; boundary="${boundary}"

--${boundary}
Content-Type: text/plain; charset=UTF-8

${body_plain}

--${boundary}
Content-Type: text/html; charset=UTF-8

${body_html}

--${boundary}--
EOF
  else
    cat > "$tmp_mail" <<EOF
From: ${SCRIPT_NAME} <${SMTP_FROM}>
To: ${SMTP_TO}
Subject: ${subject}
Date: $(date -R)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8

${body_plain}
EOF
  fi

  local tls_flag=""
  case "$SMTP_TLS" in
    starttls) tls_flag="--ssl-reqd" ;;
    ssl)      tls_flag="--ssl"      ;;
    none)     tls_flag=""           ;;
  esac

  local rcpt_flags=()
  IFS=',' read -ra _recipients <<< "$SMTP_TO"
  for _r in "${_recipients[@]}"; do
    _r="${_r// /}"
    [[ -n "$_r" ]] && rcpt_flags+=(--mail-rcpt "$_r")
  done

  local curl_exit=0
  curl --silent --show-error --connect-timeout 30 \
    --url "smtp://${SMTP_HOST}:${SMTP_PORT}" \
    ${tls_flag} \
    --user "${SMTP_USER}:${SMTP_PASS}" \
    --mail-from "${SMTP_FROM}" \
    "${rcpt_flags[@]}" \
    --upload-file "$tmp_mail" || curl_exit=$?

  rm -f "$tmp_mail"

  if [[ "$curl_exit" -eq 0 ]]; then
    echo -e "${GREEN}[✔] Email sent to: ${SMTP_TO}${RESET}"
  else
    echo -e "${YELLOW}[⚠] SMTP delivery failed (curl exit: ${curl_exit})${RESET}"
    echo -e "${YELLOW}[⚠] Debug: curl -v --url smtp://${SMTP_HOST}:${SMTP_PORT} ${tls_flag} --user '${SMTP_USER}:<pass>'${RESET}"
  fi
}

# ── JSON string escape ────────────────────────────────────────────────────────
# Safely escapes a value for embedding inside a JSON double-quoted string.
# Handles backslash, double-quote, and the common JSON control characters.
json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"    # \  →  \\  (must be first)
  s="${s//\"/\\\"}"    # "  →  \"
  s="${s//$'\n'/\\n}"  # newline → \n
  s="${s//$'\r'/\\r}"  # CR      → \r
  s="${s//$'\t'/\\t}"  # tab     → \t
  printf '%s' "$s"
}

# ── Webhook test ──────────────────────────────────────────────────────────────
webhook_test() {
  [[ -z "$WEBHOOK_URL" ]] && die "--webhook-test requires --webhook=URL to be set (or WEBHOOK_URL in config)"

  echo ""
  log "Testing webhook delivery to: ${WEBHOOK_URL}"

  local je_host
  je_host=$(json_escape "$(hostname -s)")

  # Discord gets a flat string; everyone else gets structured JSON
  local payload
  if [[ "$WEBHOOK_URL" == *"discord.com"* || "$WEBHOOK_URL" == *"discordapp.com"* ]]; then
    log "Auto-detected: Discord (using \"content\" field)"
    payload="{\"content\":\"🧪 Dispatch webhook test from ${je_host} — delivery confirmed!\"}"
  else
    log "Format: structured JSON (result / host / source / destination / duration / attempt)"
    payload="{\"result\":\"🧪 TEST\",\"host\":\"${je_host}\",\"source\":\"n/a\",\"destination\":\"n/a\",\"duration\":\"n/a\",\"attempt\":\"1/1\"}"
  fi
  echo ""

  local http_code webhook_exit=0
  http_code=$(curl --silent --show-error --connect-timeout 10 --max-time 15 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Title: Dispatch webhook test" \
    -H "Tags: rsync,test" \
    -d "$payload" \
    -w "%{http_code}" \
    -o /dev/null \
    "$WEBHOOK_URL") || webhook_exit=$?

  echo ""
  if [[ "$webhook_exit" -eq 0 && "$http_code" =~ ^2 ]]; then
    echo -e "${GREEN}[✔] Webhook test passed (HTTP ${http_code}) — check your endpoint for the test message.${RESET}"
  else
    echo -e "${RED}[✘] Webhook test failed (curl exit: ${webhook_exit}, HTTP: ${http_code:-n/a})${RESET}" >&2
    echo -e "${YELLOW}[⚠] Payload sent:${RESET}  $payload"
    echo -e "${YELLOW}[⚠] Reproduce:${RESET}     curl -v -X POST -H 'Content-Type: application/json' -d '$payload' '$WEBHOOK_URL'"
  fi
  echo ""
  return "$webhook_exit"
}

# ── Webhook dispatch ──────────────────────────────────────────────────────────
dispatch_webhook() {
  local event="$1"
  [[ -z "$WEBHOOK_URL" ]] && return 0

  local fire=false
  case "$WEBHOOK_ON" in
    always)   fire=true ;;
    failure)  [[ "$event" == "failed"   || "$event" == "interrupted" ]] && fire=true ;;
    success)  [[ "$event" == "success"  || "$event" == "warnings"    ]] && fire=true ;;
    warnings) [[ "$event" == "warnings"                               ]] && fire=true ;;
  esac
  $fire || return 0

  local icon status_text
  case "$event" in
    success)     icon="✅";  status_text="SUCCESS" ;;
    warnings)    icon="⚠️";  status_text="SUCCESS (with warnings)" ;;
    failed)      icon="❌";  status_text="FAILED (exit: ${RSYNC_EXIT:-?})" ;;
    interrupted) icon="🛑";  status_text="INTERRUPTED" ;;
    *)           icon="ℹ️";  status_text="$event" ;;
  esac

  local dry_note=""
  $IS_DRY_RUN && dry_note=" [DRY RUN]"

  # Escape every dynamic value individually — each becomes its own JSON field.
  # This produces a structured, machine-parseable payload instead of a flat
  # newline-joined string, making it easy to consume in automations and bots.
  local je_result je_host je_src je_dest je_elapsed je_attempt
  je_result=$(json_escape "${icon}${dry_note} ${status_text}")
  je_host=$(json_escape "$(hostname -s)")
  je_src=$(json_escape "${SRC_ARG:-n/a}")
  je_dest=$(json_escape "${DEST_ARG:-n/a}")
  je_elapsed=$(json_escape "${ELAPSED_FMT:-in progress}")
  je_attempt=$(json_escape "${ATTEMPT:-1}/$((RETRY_COUNT + 1))")

  # Build a structured JSON payload — one field per piece of data.
  # Discord uses a single "content" field, so we fall back to a formatted
  # string for Discord only.  Everyone else gets the structured object.
  local payload
  if [[ "$WEBHOOK_URL" == *"discord.com"* || "$WEBHOOK_URL" == *"discordapp.com"* ]]; then
    # Discord only supports a single "content" string field
    local discord_msg
    discord_msg=$(json_escape "${icon}${dry_note} ${status_text}\nHost: $(hostname -s)\nSource: ${SRC_ARG:-n/a}\nDest: ${DEST_ARG:-n/a}\nDuration: ${ELAPSED_FMT:-in progress}\nAttempt: ${ATTEMPT:-1}/$((RETRY_COUNT + 1))")
    payload="{\"content\":\"${discord_msg}\"}"
  else
    payload=$(printf '{"result":"%s","host":"%s","source":"%s","destination":"%s","duration":"%s","attempt":"%s"}' \
      "$je_result" "$je_host" "$je_src" "$je_dest" "$je_elapsed" "$je_attempt")
  fi

  # Capture the HTTP status code.  curl exits 0 even on 4xx/5xx responses,
  # so we must inspect the code to detect silent rejections (e.g. Discord
  # returning 400 because the wrong field name was used).
  local http_code webhook_exit=0
  http_code=$(curl --silent --show-error --connect-timeout 10 --max-time 15 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Title: Dispatch ${status_text}" \
    -H "Tags: rsync,backup" \
    -d "$payload" \
    -w "%{http_code}" \
    -o /dev/null \
    "$WEBHOOK_URL") || webhook_exit=$?

  if [[ "$webhook_exit" -eq 0 && "$http_code" =~ ^2 ]]; then
    echo -e "${GREEN}[✔] Webhook delivered (HTTP ${http_code}): ${WEBHOOK_URL}${RESET}"
  else
    echo -e "${YELLOW}[⚠] Webhook delivery failed (curl exit: ${webhook_exit}, HTTP: ${http_code:-n/a}): ${WEBHOOK_URL}${RESET}"
    echo -e "${YELLOW}[⚠] Debug: curl -v -X POST -H 'Content-Type: application/json' -d '${payload}' '${WEBHOOK_URL}'${RESET}"
  fi
}

# ── Dead man's switch / heartbeat ping ───────────────────────────────────────
dispatch_ping() {
  local event="$1"
  [[ -z "$PING_URL" ]] && return 0

  if [[ "$event" != "success" && "$event" != "warnings" ]]; then
    $QUIET || echo -e "${CYAN}[$(ts)]${RESET} Ping skipped — event '${event}' is not a success."
    return 0
  fi

  local ping_exit=0
  curl --silent --show-error --max-time 10 \
    "$PING_URL" >/dev/null || ping_exit=$?

  if [[ "$ping_exit" -eq 0 ]]; then
    echo -e "${GREEN}[✔] Heartbeat pinged: ${PING_URL}${RESET}"
  else
    echo -e "${YELLOW}[⚠] Heartbeat ping failed (curl exit: ${ping_exit}): ${PING_URL}${RESET}"
  fi
}

# ── Build and dispatch email ──────────────────────────────────────────────────
dispatch_email() {
  local event="$1"
  local subject_tag icon status_line color

  case "$event" in
    start)
      subject_tag="STARTED";  icon=">>"; status_line="Sync has started"; color="#2196F3" ;;
    success)
      subject_tag="SUCCESS";  icon="OK"; status_line="Sync completed successfully"; color="#4CAF50" ;;
    warnings)
      subject_tag="WARNINGS"; icon="!!"; status_line="Sync completed with warnings (exit 24 -- files vanished mid-transfer)"; color="#FF9800" ;;
    failed)
      subject_tag="FAILED";   icon="XX"; status_line="Sync FAILED (rsync exit code: ${RSYNC_EXIT:-?})"; color="#F44336" ;;
    interrupted)
      subject_tag="INTERRUPTED"; icon="!!"; status_line="Sync was interrupted by signal"; color="#9C27B0" ;;
  esac

  local dry_tag=""
  $IS_DRY_RUN && dry_tag=" [DRY RUN]"

  local src_dest_tag=""
  if [[ -n "$SRC_ARG" && -n "$DEST_ARG" ]]; then
    src_dest_tag=" — ${SRC_ARG} → ${DEST_ARG}"
  elif [[ -n "$DEST_ARG" ]]; then
    src_dest_tag=" → ${DEST_ARG}"
  fi

  local subject="[dispatch]${dry_tag} ${subject_tag}${src_dest_tag} ($(hostname -s), ${ELAPSED_FMT:-in progress})"

  local output_section=""
  if [[ -s "$STATS_TMP" ]]; then
    output_section="---- rsync output ----
$(cat "$STATS_TMP")
-----------------------"
  else
    output_section="(no output captured)"
  fi

  local plain_body
  plain_body=$(cat <<EOF
${SCRIPT_NAME} v${VERSION} — Sync Report
$( printf '=%.0s' {1..45} )
Status      : [${icon}] ${status_line}${dry_tag}
${PARSED_STATS:-}
Source      : ${SRC_ARG:-n/a}
