)

  if $SMTP_ENABLED; then
    $QUIET || echo -e "${CYAN}[$(ts)]${RESET} Dispatching ${event} email to: ${SMTP_TO}..."
    send_smtp_email "$subject" "$plain_body" "$html_body"
  fi
}

# ── Signal trap ───────────────────────────────────────────────────────────────
INTERRUPTED=false
handle_signal() {
  INTERRUPTED=true
  echo ""
  echo -e "${YELLOW}[⚠] Signal received -- rsync interrupted.${RESET}"
  END_DATE="$(ts)"
  local end_epoch
  end_epoch=$(date +%s)
  ELAPSED=$(( end_epoch - START_TIME ))
  ELAPSED_FMT=$(printf '%02dh:%02dm:%02ds' $(( ELAPSED/3600 )) $(( (ELAPSED%3600)/60 )) $(( ELAPSED%60 )))
  RSYNC_EXIT=130
  parse_rsync_stats
  dispatch_email "interrupted"
  dispatch_webhook "interrupted"
  release_lock
  exit 130
}

trap handle_signal SIGINT SIGTERM

# ── Shared state ──────────────────────────────────────────────────────────────
START_TIME=$(date +%s)
START_DATE="$(ts)"
END_DATE=""
ELAPSED_FMT=""
RSYNC_EXIT=0
PARSED_STATS=""
ATTEMPT=1

# ── Acquire lock ──────────────────────────────────────────────────────────────
acquire_lock

# ── Display header ────────────────────────────────────────────────────────────
LOG_LABEL="$( $LOG_ENABLED && echo "$LOG_FILE" || echo "disabled" )"
SMTP_LABEL="$( $SMTP_ENABLED && echo "enabled (notify: ${NOTIFY_ON})" || echo "disabled" )"
WEBHOOK_LABEL="$( [[ -n "$WEBHOOK_URL" ]] && echo "${WEBHOOK_URL} (on: ${WEBHOOK_ON})" || echo "disabled" )"
PING_LABEL="$( [[ -n "$PING_URL" ]] && echo "${PING_URL}" || echo "disabled" )"

$QUIET || cat << 'ASCIIART'
╔═══════════════════════════════════════════════════════════════════════════╗
║                                                                           ║
║   ██████╗  ██╗ ███████╗ ██████╗   █████╗  ████████╗  ██████╗ ██╗  ██╗     ║
║   ██╔══██╗ ██║ ██╔════╝ ██╔══██╗ ██╔══██╗ ╚══██╔══╝ ██╔════╝ ██║  ██║     ║
║   ██║  ██║ ██║ ███████╗ ██████╔╝ ███████║    ██║    ██║      ███████║     ║
║   ██║  ██║ ██║ ╚════██║ ██╔═══╝  ██╔══██║    ██║    ██║      ██╔══██║     ║
║   ██████╔╝ ██║ ███████║ ██║      ██║  ██║    ██║    ╚██████╗ ██║  ██║     ║
║   ╚═════╝  ╚═╝ ╚══════╝ ╚═╝      ╚═╝  ╚═╝    ╚═╝     ╚═════╝ ╚═╝  ╚═╝     ║
║                                                                           ║
║                   ◄──── notify · rsync · deliver ────►                    ║
║                                                                           ║
ASCIIART
$QUIET || printf "║%s      Dispatch · Smart rsync notifications · v%-6s      %s║\n" "         " "${VERSION}" "        "
$QUIET || echo "╚═══════════════════════════════════════════════════════════════════════════╝"
banner
log "Real rsync  : $RSYNC_BIN"
log "Source      : ${SRC_ARG:-n/a}"
log "Destination : ${DEST_ARG:-n/a}"
log "Arguments   : ${RSYNC_ARGS[*]}"
log "Dry run     : $IS_DRY_RUN"
log "Log file    : $LOG_LABEL"
log "SMTP        : $SMTP_LABEL"
log "Webhook     : $WEBHOOK_LABEL"
log "Ping URL    : $PING_LABEL"
[[ -n "$PRE_HOOK"  ]] && log "Pre-hook    : $PRE_HOOK"
[[ -n "$POST_HOOK" ]] && log "Post-hook   : $POST_HOOK"
[[ "$RETRY_COUNT" -gt 0 ]] && log "Retry       : up to ${RETRY_COUNT}x with ${RETRY_DELAY}s delay"
banner
echo ""

# ── Pre-hook ──────────────────────────────────────────────────────────────────
if [[ -n "$PRE_HOOK" ]]; then
  log "Running pre-hook: $PRE_HOOK"
  if "$PRE_HOOK"; then
    echo -e "${GREEN}[✔] Pre-hook completed.${RESET}"
  else
    echo -e "${YELLOW}[⚠] Pre-hook exited non-zero -- continuing with rsync anyway.${RESET}"
  fi
fi

# ── Start notification ────────────────────────────────────────────────────────
if $SMTP_ENABLED && $NOTIFY_START; then
  dispatch_email "start"
fi

# ── Write run header ──────────────────────────────────────────────────────────
{
  echo "${SCRIPT_NAME} v${VERSION} run -- $(date)"
  echo "Binary      : $RSYNC_BIN"
  echo "Source      : ${SRC_ARG:-n/a}"
  echo "Destination : ${DEST_ARG:-n/a}"
  echo "Arguments   : ${RSYNC_ARGS[*]}"
  echo "Dry run     : $IS_DRY_RUN"
  echo "SMTP        : $SMTP_LABEL"
  echo "Log file    : $LOG_LABEL"
  echo "============================================"
} | tee_output

# ── rsync execution with retry ────────────────────────────────────────────────
RSYNC_EXIT=1

for (( ATTEMPT=1; ATTEMPT <= RETRY_COUNT + 1; ATTEMPT++ )); do
  if [[ $ATTEMPT -gt 1 ]]; then
    echo -e "${YELLOW}[⚠] Retry attempt ${ATTEMPT}/$((RETRY_COUNT + 1)) in ${RETRY_DELAY}s...${RESET}"
    sleep "$RETRY_DELAY"
    write_output ""
    write_output "============================================"
    write_output "RETRY ATTEMPT ${ATTEMPT} -- $(date)"
    write_output "============================================"
  fi

  set +e
  "$RSYNC_BIN" "${RSYNC_ARGS[@]}" 2>&1 | tee_output
  RSYNC_EXIT="${PIPESTATUS[0]}"
  set -e

  if [[ "$RSYNC_EXIT" -eq 0 || "$RSYNC_EXIT" -eq 24 ]]; then
    break
  fi

  if [[ $ATTEMPT -le $RETRY_COUNT ]]; then
    echo -e "${YELLOW}[⚠] rsync failed (exit ${RSYNC_EXIT}) -- will retry...${RESET}"
    write_output "rsync exit ${RSYNC_EXIT} -- retry ${ATTEMPT}/${RETRY_COUNT} scheduled"
  fi
done

# ── Timing ────────────────────────────────────────────────────────────────────
END_TIME=$(date +%s)
END_DATE="$(ts)"
ELAPSED=$(( END_TIME - START_TIME ))
ELAPSED_FMT=$(printf '%02dh:%02dm:%02ds' $(( ELAPSED/3600 )) $(( (ELAPSED%3600)/60 )) $(( ELAPSED%60 )))

# ── Parse stats ───────────────────────────────────────────────────────────────
parse_rsync_stats

# ── Determine event ───────────────────────────────────────────────────────────
EVENT=""
if [[ "$RSYNC_EXIT" -eq 0 ]]; then
  EVENT="success"
  echo -e "${GREEN}[✔] rsync completed successfully.${RESET}"
elif [[ "$RSYNC_EXIT" -eq 24 ]]; then
  EVENT="warnings"
  echo -e "${YELLOW}[⚠] rsync completed with warnings (exit 24 -- some files vanished mid-transfer).${RESET}"
else
  EVENT="failed"
  echo -e "${RED}[✘] rsync FAILED after $ATTEMPT attempt(s). Exit code: $RSYNC_EXIT${RESET}" >&2
fi

{
  echo "============================================"
  echo "Status      : ${EVENT^^}"
  echo "Duration    : $ELAPSED_FMT"
  echo "Attempts    : $ATTEMPT"
  echo "Finished    : $END_DATE"
  [[ -n "$PARSED_STATS" ]] && echo -e "$PARSED_STATS"
  echo "============================================"
} | tee_output

# ── Post-hook ─────────────────────────────────────────────────────────────────
if [[ -n "$POST_HOOK" ]]; then
  log "Running post-hook: $POST_HOOK"
  if RSYNC_EXIT_CODE="$RSYNC_EXIT" "$POST_HOOK"; then
    echo -e "${GREEN}[✔] Post-hook completed.${RESET}"
  else
    echo -e "${YELLOW}[⚠] Post-hook exited non-zero.${RESET}"
  fi
fi

# ── Log rotation ──────────────────────────────────────────────────────────────
rotate_logs

# ── SMTP dispatch ─────────────────────────────────────────────────────────────
should_notify=false
case "$NOTIFY_ON" in
  always)   should_notify=true ;;
  failure)  [[ "$EVENT" == "failed"   || "$EVENT" == "interrupted" ]] && should_notify=true ;;
  success)  [[ "$EVENT" == "success"                               ]] && should_notify=true ;;
  warnings) [[ "$EVENT" == "warnings"                              ]] && should_notify=true ;;
esac

if $SMTP_ENABLED && $should_notify; then
  dispatch_email "$EVENT"
elif $SMTP_ENABLED && ! $should_notify; then
  $QUIET || echo -e "${CYAN}[$(ts)]${RESET} SMTP enabled but notify=${NOTIFY_ON} — skipping email for '${EVENT}' event."
else
  $QUIET || echo -e "${CYAN}[$(ts)]${RESET} SMTP disabled — skipping email notification."
fi

# ── Webhook dispatch ──────────────────────────────────────────────────────────
[[ -n "$WEBHOOK_URL" ]] && dispatch_webhook "$EVENT"

# ── Heartbeat ping ────────────────────────────────────────────────────────────
[[ -n "$PING_URL" ]] && dispatch_ping "$EVENT"

# ── Release lock ──────────────────────────────────────────────────────────────
release_lock

# ── Footer ────────────────────────────────────────────────────────────────────
echo ""
banner
$LOG_ENABLED && log "Log saved to : $LOG_FILE" || true
log "Done in      : $ELAPSED_FMT"
banner
echo ""

exit "$RSYNC_EXIT"
