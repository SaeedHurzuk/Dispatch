    local _escaped_output
    _escaped_output=$(sed 's/&/\&amp;/g; s/</\&lt;/g; s/>/\&gt;/g' "$STATS_TMP" | sed 's/$/<br>/')
    rsync_html_output="<div style='background:#1e1e1e;color:#d4d4d4;padding:16px;border-radius:6px;font-size:12px;overflow-x:auto;font-family:monospace;line-height:1.5;'>${_escaped_output}</div>"
